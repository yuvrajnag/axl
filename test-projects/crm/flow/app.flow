APP crm
NAME "SalesForceClone"
VERSION 1.0.0
DESCRIPTION "CRM"
FRAMEWORK Express
LANGUAGE JavaScript
DATABASE MongoDB
BASE_URL https://api.crm.com

ENTITY Lead
  id : String
  name : String

ACTION create_lead
  DESC "Create Lead"
  INPUT
    name : String REQUIRED
  OUTPUT Lead
  ENDPOINT POST /leads

PERMISSION create_lead : AUTH
