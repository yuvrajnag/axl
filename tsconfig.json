{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "."
  },
  "files": [],
  "references": [
    { "path": "packages/compiler" },
    { "path": "packages/cli" },
    { "path": "packages/generators" }
  ],
  "exclude": ["node_modules", "dist", "build", "examples"]
}
