{
  "name": "axl-flow",
  "displayName": "AXL Flow Language",
  "description": "Syntax highlighting, hover tooltips, inline diagnostics, snippets, and format-on-save for the AXL .flow specification language",
  "version": "0.2.0",
  "publisher": "axl",
  "icon": "icons/flow.svg",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": ["Programming Languages", "Linters", "Formatters", "Snippets"],
  "main": "./dist/extension.js",
  "files": [
    "dist",
    "syntaxes",
    "snippets",
    "language-configuration.json",
    "icons"
  ],
  "activationEvents": [
    "onLanguage:flow"
  ],
  "contributes": {
    "languages": [
      {
        "id": "flow",
        "aliases": ["AXL Flow", "flow"],
        "extensions": [".flow"],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/flow.svg",
          "dark": "./icons/flow.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "flow",
        "scopeName": "source.flow",
        "path": "./syntaxes/flow.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "flow",
        "path": "./snippets/flow.code-snippets"
      }
    ]
  },
  "scripts": {
    "build": "tsc --noEmit && npm run bundle",
    "bundle": "esbuild src/extension.ts --bundle --platform=node --format=cjs --outfile=dist/extension.js --external:vscode --sourcemap"
  },
  "devDependencies": {
    "@axl/compiler": "0.1.0",
    "@types/vscode": "^1.60.0",
    "esbuild": "^0.28.1"
  }
}
