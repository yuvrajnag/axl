{
  "name": "axl",
  "version": "1.0.0",
  "description": "AXL command-line interface — compile, validate, doctor, init",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "axl": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && npm run bundle",
    "bundle": "esbuild index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --allow-overwrite"
  },
  "devDependencies": {
    "@axl/compiler": "1.0.0",
    "@axl/generators": "1.0.0",
    "esbuild": "^0.25.0"
  },
  "license": "MIT"
}
